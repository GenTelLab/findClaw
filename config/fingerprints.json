{
  "version": "4.0",
  "rules": [
    {
      "id": "openclaw-header-version",
      "name": "OpenClaw Header Version",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 110,
      "conditions": {
        "allOf": [
          {
            "type": "http_header",
            "headerName": "X-Claw-Version",
            "match": { "exists": true }
          }
        ]
      },
      "versionExtract": {
        "from": "header",
        "headerName": "X-Claw-Version",
        "regex": "(\\d+\\.\\d+\\.\\d+)"
      },
      "confidenceScore": 95
    },
    {
      "id": "openclaw-control-ui",
      "name": "OpenClaw Control UI",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 108,
      "conditions": {
        "allOf": [
          {
            "type": "http_path_response",
            "path": "/",
            "match": {
              "statusCode": 200,
              "bodyContains": ["openclaw"],
              "bodyNotContains": ["autoclaw", "miniclaw", "findclaw"]
            }
          }
        ]
      },
      "confidenceScore": 92
    },
    {
      "id": "openclaw-tools-api-stack",
      "name": "OpenClaw Tool API Stack",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 106,
      "conditions": {
        "allOf": [
          {
            "type": "http_path_response",
            "path": "/tools/invoke",
            "match": { "statusCodeIn": [401, 405] }
          },
          {
            "type": "http_path_response",
            "path": "/v1/chat/completions",
            "match": { "statusCodeIn": [401, 405] }
          },
          {
            "type": "http_path_response",
            "path": "/v1/responses",
            "match": { "statusCodeIn": [401, 405] }
          }
        ]
      },
      "confidenceScore": 93
    },
    {
      "id": "openclaw-status-signals",
      "name": "OpenClaw Status Signals",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 102,
      "conditions": {
        "anyOf": [
          {
            "type": "http_path_response",
            "path": "/health",
            "match": {
              "statusCode": 200,
              "bodyContains": ["channel", "running", "probe"],
              "operator": "AND"
            }
          },
          {
            "type": "http_path_response",
            "path": "/status",
            "match": {
              "statusCodeIn": [200, 401, 403],
              "bodyContains": ["openclaw", "channel", "gateway"],
              "operator": "OR"
            }
          },
          {
            "type": "http_path_response",
            "path": "/version",
            "match": {
              "statusCodeIn": [200, 401, 403],
              "bodyContains": ["openclaw", "claw"],
              "operator": "OR"
            }
          }
        ]
      },
      "confidenceScore": 88
    },
    {
      "id": "openclaw-root-assets",
      "name": "OpenClaw Asset Hints",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 98,
      "conditions": {
        "allOf": [
          {
            "type": "http_path_response",
            "path": "/",
            "match": {
              "appHintContains": ["openclaw"],
              "bodyNotContains": ["findclaw"],
              "assetPathNotContains": ["autoclaw", "miniclaw"],
              "titleNotContains": ["findclaw"]
            }
          }
        ]
      },
      "confidenceScore": 84
    },
    {
      "id": "openclaw-mcp-stream",
      "name": "OpenClaw MCP Stream",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 96,
      "conditions": {
        "allOf": [
          {
            "type": "sse_available",
            "match": {}
          },
          {
            "type": "nse_output_contains",
            "match": {
              "anyOf": ["signal=mcp:event-stream"]
            }
          }
        ]
      },
      "confidenceScore": 82
    },
    {
      "id": "openclaw-mdns-beacon",
      "name": "OpenClaw mDNS Beacon",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 94,
      "conditions": {
        "allOf": [
          {
            "type": "nmap_service_contains",
            "match": { "contains": "mdns-openclaw" }
