        ]
      },
      "confidenceScore": 85
    },
    {
      "id": "openclaw-nse-detect",
      "name": "OpenClaw NSE Detect",
      "familyName": "OpenClaw",
      "category": "confirmed",
      "priority": 92,
      "conditions": {
        "allOf": [
          {
            "type": "nse_output_contains",
            "match": {
              "anyOf": [
                "claw_detect=openclaw",
                "claw_detect=openclaw_gateway",
                "signal=root:openclaw",
                "signal=health:openclaw",
                "signal=status:openclaw",
                "signal=version:openclaw"
              ]
            }
          }
        ]
      },
      "versionExtract": {
        "from": "nse_output",
        "regex": "signal=header:x-claw-version=([0-9]+\\.[0-9]+\\.[0-9]+)"
      },
      "confidenceScore": 87
    },
