  "exclusions": [
    { "id": "exclude-mysql",        "match": { "portEquals": 3306 } },
    { "id": "exclude-redis",        "match": { "portEquals": 6379 } },
    { "id": "exclude-postgres",     "match": { "portEquals": 5432 } },
    { "id": "exclude-mongo",        "match": { "portEquals": 27017 } },
    { "id": "exclude-elasticsearch","match": { "portEquals": 9200 } },
    { "id": "exclude-nginx",        "match": { "serverHeaderContains": "nginx" } },
    { "id": "exclude-apache",       "match": { "serverHeaderContains": "Apache" } },
    { "id": "exclude-iis",          "match": { "serverHeaderContains": "Microsoft-IIS" } },
    { "id": "exclude-tomcat",       "match": { "serverHeaderContains": "Apache-Coyote" } },
    { "id": "exclude-jupyter",      "match": { "serverHeaderContains": "TornadoServer" } },
    { "id": "exclude-grafana",      "match": { "serverHeaderContains": "Grafana" } },
    { "id": "exclude-express",      "match": { "serverHeaderContains": "Express" } },
    { "id": "exclude-spring-boot",  "match": { "serverHeaderContains": "Spring" } },
    { "id": "exclude-whitelabel",   "match": { "titleContains": "Whitelabel Error Page" } },
    { "id": "exclude-express-body", "match": { "bodyContains": "Cannot GET /" } },
    { "id": "exclude-django",       "match": { "bodyContains": "The install worked successfully!" } },
    { "id": "exclude-flask",        "match": { "bodyContains": "Werkzeug" } },
    { "id": "exclude-tensorboard",  "match": { "serverHeaderContains": "TensorBoard" } },
    { "id": "exclude-prometheus",   "match": { "serverHeaderContains": "Prometheus" } }
  ]
